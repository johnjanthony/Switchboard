# Copy to .env and fill in. OS env vars take precedence over .env.

# Optional — defaults shown
# Set to 0.0.0.0 if any MCP clients run in WSL — the default 127.0.0.1
# is loopback-only and silently drops connections from the WSL subnet.
SWITCHBOARD_HOST=127.0.0.1
SWITCHBOARD_PORT=9876
SWITCHBOARD_TIMEOUT_SECONDS=86400
SWITCHBOARD_LOG_PATH=./logs/switchboard.jsonl
# SWITCHBOARD_RATE_LIMIT=30

# How long an ended conversation survives (index card + /messages + /answers)
# before the retention sweep deletes it. Hours; default 72.
# SWITCHBOARD_CONVERSATION_RETENTION_HOURS=72

# Shared-secret gate (REV-003). REQUIRED when SWITCHBOARD_HOST is non-loopback:
# the server refuses to start without it. Non-loopback clients (WSL agents,
# their hooks) must send "Authorization: Bearer <token>"; loopback callers and
# /healthz are exempt. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# SWITCHBOARD_TOKEN=

# Coarse per-route rate limit for the unauthenticated POST routes
# (/widget-snapshot, /session_start, /agent_status).
# Requests/min per route; 0 disables.
# SWITCHBOARD_ROUTE_RATE_LIMIT=600

# Firebase (REQUIRED). The server exits at startup with a ConfigError if
# FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_DATABASE_URL is unset.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_DATABASE_URL=
# Optional: Firebase Storage bucket hostname, for send_document_human delivery.
# FIREBASE_STORAGE_BUCKET=

# Optional — enable Claude Code spawning from the phone.
# Windows surface: root directory containing your project folders.
# SWITCHBOARD_SPAWN_ROOT is accepted as a legacy alias for back-compat.
# SWITCHBOARD_WINDOWS_SPAWN_ROOT=C:\Work

# WSL surface: segment appended to the resolved WSL home to locate the workspace
# root (e.g. wsl_home=/home/john + segment=work → /home/john/work). Default: work.
# SWITCHBOARD_WSL_SPAWN_ROOT_SEGMENT=work

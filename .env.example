# Copy to .env and fill in. OS env vars take precedence over .env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — defaults shown
SWITCHBOARD_HOST=127.0.0.1
SWITCHBOARD_PORT=9876
SWITCHBOARD_TIMEOUT_SECONDS=86400
SWITCHBOARD_LOG_PATH=./logs/switchboard.jsonl
SWITCHBOARD_ENABLE_ANDROID=false

# Optional — enable Telegram-triggered Claude Code spawning
# Set to the root directory containing your project folders
# SWITCHBOARD_SPAWN_ROOT=C:\Work

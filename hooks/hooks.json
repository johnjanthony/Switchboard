{
	"hooks": {
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/turn-end-hook-away-mode.py --cli claude",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/agent-status-hook.py",
						"timeout": 2
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/agent-status-hook.py",
						"timeout": 2
					}
				]
			}
		],
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/agent-status-hook.py",
						"timeout": 2
					},
					{
						"type": "command",
						"command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/cli-session-injector-hook.py",
						"timeout": 2
					}
				]
			}
		],
		"PostToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/agent-status-hook.py",
						"timeout": 2
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python ${CLAUDE_PLUGIN_ROOT}/scripts/cli-session-end-hook.py",
						"timeout": 5
					}
				]
			}
		]
	}
}
